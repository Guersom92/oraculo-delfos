---
// OracleBusy.astro — Shown when the rate limit has been reached
---

  <div id="oracle-busy"  class="busy-scene hidden">

    <!-- Busy message card -->
    <div class="busy-card">

      
      <p class="busy-excuse" id="busy-excuse-text">
        <!-- Filled by JS -->
      </p>

      <div class="busy-countdown-wrapper">
        <p class="busy-countdown-label cinzel">Regresa en</p>
        <div class="busy-countdown" id="busy-countdown">--</div>
        <p class="busy-countdown-unit cinzel">segundos</p>
      </div>

    </div>

  </div>
</div>

<style>
  

  .busy-scene {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    gap: 0.2rem;
  }

  .busy-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 1rem 1.5rem;
    text-align: center;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow:
      0 0 40px rgba(0,0,0,0.6),
      inset 0 0 60px rgba(0,0,0,0.3);
    position: relative;
    overflow: hidden;
  }

  .busy-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Corner ornaments */
  .busy-card::after {
    content: '❧';
    position: absolute;
    bottom: 1rem;
    right: 1.5rem;
    color: var(--gold-dark);
    font-size: 1.2rem;
    opacity: 0.4;
  }


  
  .busy-excuse {
    font-style: italic;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 360px;
    min-height: 3rem;
  }

  .busy-countdown-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0.5rem 0;
  }

  .busy-countdown-label,
  .busy-countdown-unit {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .busy-countdown {
    font-family: 'Cinzel', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    text-shadow: 0 0 20px rgba(201,168,76,0.4);
    letter-spacing: 0.05em;
    animation: countdown-tick 1s ease-in-out infinite;
    min-width: 4rem;
    text-align: center;
  }

  @keyframes countdown-tick {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.7; }
  }
</style>
