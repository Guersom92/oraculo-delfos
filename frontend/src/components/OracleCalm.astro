  <!-- Ambient ground glow -->
  <div class="pythia-ground-glow" aria-hidden="true"></div>
   <!-- Question form -->
        <div class="oracle-form-wrapper">

          <form id="oracle-form" class="oracle-form" novalidate>
            <div class="input-wrapper">
              <textarea
                id="oracle-question"
                class="oracle-textarea"
                name="question"
                rows="3"
                maxlength="500"
                placeholder="¿Qué desea saber de los dioses…?"
                aria-label="Tu pregunta al Oráculo"
                required
              ></textarea>
              <div class="input-border-glow" aria-hidden="true"></div>
            </div>

            <button type="submit" id="btn-consult" class="oracle-btn cinzel" aria-label="Consultar al Oráculo">
              <span class="btn-ornament" aria-hidden="true">✦</span>
              <span class="btn-text">Consultar al Oráculo</span>
              <span class="btn-ornament" aria-hidden="true">✦</span>
            </button>
          </form>

          <!-- Form error -->
          <p id="form-error" class="form-error hidden" role="alert"></p>
        </div>

</div>

<style>
  /* ── Form ── */
  .oracle-form-wrapper {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  

  .oracle-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .input-wrapper {
    position: relative;
    width: 100%;
  }

  .oracle-textarea {
    width: 100%;
    padding: 0.5rem;
    background: rgba(10, 7, 3, 0.8);
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text);
    font-family: 'IM Fell English', Georgia, serif;
    font-size: 1rem;
    line-height: 1.6;
    resize: vertical;
    min-height: 90px;
    transition: border-color 0.3s, box-shadow 0.3s;
    outline: none;
    letter-spacing: 0.02em;
  }

  .oracle-textarea::placeholder {
    color: var(--text-muted);
    font-style: italic;
    opacity: 0.6;
  }

  .oracle-textarea:focus {
    border-color: var(--gold-dark);
    box-shadow:
      0 0 0 1px rgba(201,168,76,0.15),
      0 0 20px rgba(201,168,76,0.08);
  }

  .oracle-textarea:focus + .input-border-glow {
    opacity: 1;
  }

  .input-border-glow {
    position: absolute;
    inset: -1px;
    border-radius: 2px;
    background: transparent;
    box-shadow: 0 0 30px rgba(201,168,76,0.1);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s;
  }
    /* ── Form error ── */
  .form-error {
    color: #C87050;
    font-style: italic;
    font-size: 0.9rem;
    text-align: center;
  }

  /* ── Pythia SVG ── */
  .pythia-container {
width:100%;
display:flex;
align-items: center;
flex-direction: column;
justify-content: center;
    flex-shrink: 0;
  }

  .pythia-svg {
    width: 200px;
    animation: pythia-idle 8s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(201, 168, 76, 0.25));
    position: relative;
    z-index: 2;
  }

  @keyframes pythia-idle {
    0%,
    100% {
      transform: translateY(0) rotate(-0.3deg);
      transform-origin: bottom center;
    }
    33% {
      transform: translateY(-4px) rotate(0.2deg);
      transform-origin: bottom center;
    }
    66% {
      transform: translateY(-2px) rotate(-0.4deg);
      transform-origin: bottom center;
    }
  }

  .pythia-ground-glow {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    height: 30px;
    background: radial-gradient(
      ellipse,
      rgba(201, 168, 76, 0.25) 0%,
      transparent 70%
    );
    border-radius: 50%;
    z-index: 1;
    animation: ground-pulse 4s ease-in-out infinite;
  }

  @keyframes ground-pulse {
    0%,
    100% {
      opacity: 0.6;
      transform: translateX(-50%) scaleX(1);
    }
    50% {
      opacity: 1;
      transform: translateX(-50%) scaleX(1.1);
    }
  }
</style>
