---
import Layout from "../layouts/Layout.astro";
import OracleTrance from "../components/OracleTrance.astro";
import OracleBusy from "../components/OracleBusy.astro";
import OracleCalm from "../components/OracleCalm.astro";
import Profecy from "../components/Profecy.astro";
---

<Layout title="El Oráculo de Delfos">
  <main class="oracle-main">
    <header class="oracle-header">
      <div class="header-titles">
        <h1 class="header-title cinzel">El Oráculo</h1>
        <p class="header-tagline">La Pitia habla por boca del dios</p>
      </div>
      <div class="meander header-meander"></div>
    </header>

    <OracleCalm />
    <OracleTrance />
    <OracleBusy />
    <Profecy />
  </main>
</Layout>

<style>
  /* ── Layout ── */
  .oracle-main {
    padding: 1rem;
    max-height: 100svh;
    display: flex;
    flex-direction: column;
    max-width: 680px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .state-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Header ── */
  .oracle-header {
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
    align-items: center;
    gap: 0.8rem;
  }

  .header-titles {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .header-title {
    font-size: 3.2rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--gold-light);
    text-shadow:
      0 0 40px rgba(201, 168, 76, 0.5),
      0 0 80px rgba(201, 168, 76, 0.2);
    animation: title-shimmer 6s ease-in-out infinite;
  }

  @keyframes title-shimmer {
    0%,
    100% {
      text-shadow:
        0 0 40px rgba(201, 168, 76, 0.5),
        0 0 80px rgba(201, 168, 76, 0.2);
    }
    50% {
      text-shadow:
        0 0 60px rgba(201, 168, 76, 0.7),
        0 0 100px rgba(201, 168, 76, 0.3);
    }
  }

  .header-tagline {
    font-style: italic;
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .header-meander {
    max-width: 360px;
  }

  @media (max-width: 480px) {
    .oracle-header{
      margin-bottom: 4rem;
    }
  }
  
</style>

<!-- ═══════════════════════════════════════
     CLIENT SCRIPT — Initialization
═══════════════════════════════════════ -->
<script>
  import { initOracleScript } from "../scripts/oracle";

  initOracleScript();
</script>
